<Window x:Class="HideIt.Views.HideWindowDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hide a specific window"
        Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8"
                   Text="Tick the exact windows to hide — handy when one app (e.g. Chrome) has several windows and you only want to hide some. Bring one back with the &quot;Show last hidden&quot; shortcut, or Restore all." />

        <ListBox Grid.Row="1" x:Name="List" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="2">
                        <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                            <Image Source="{Binding Icon}" Width="20" Height="20" Margin="0,0,8,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" MaxWidth="400" />
                                <TextBlock Text="{Binding ProcessName}" Foreground="Gray" FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                    </CheckBox>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="2" Content="Refresh list" HorizontalAlignment="Left"
                Margin="0,8,0,0" Padding="10,4" Click="Refresh_Click" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Hide selected" Width="120" Margin="0,0,8,0" IsDefault="True" Click="Hide_Click" />
            <Button Content="Cancel" Width="80" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
