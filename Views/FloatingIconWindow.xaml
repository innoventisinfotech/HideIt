<Window x:Class="HideIt.Views.FloatingIconWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Title="HideIt">
    <Border x:Name="Root"
            Width="48" Height="48"
            CornerRadius="10"
            Background="#CC202020"
            BorderBrush="#66FFFFFF"
            BorderThickness="1"
            Padding="4"
            ToolTip="Click to hide/show. Drag to move. Right-click for options.">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.5" />
        </Border.Effect>
        <Image x:Name="IconImage" Width="32" Height="32" Stretch="Uniform" />
    </Border>
</Window>
