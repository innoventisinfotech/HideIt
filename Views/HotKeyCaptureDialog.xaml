<Window x:Class="HideIt.Views.HotKeyCaptureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set shortcut"
        Width="360" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FocusManager.FocusedElement="{Binding ElementName=CaptureBox}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Press the key combination you want (at least one of Ctrl / Alt / Shift / Win)."
                   TextWrapping="Wrap" Margin="0,0,0,12" />

        <Border Grid.Row="1"
                x:Name="CaptureBox"
                Focusable="True"
                Background="#FFF3F3F3"
                BorderBrush="#FFB0B0B0"
                BorderThickness="1"
                CornerRadius="4"
                PreviewKeyDown="CaptureBox_PreviewKeyDown">
            <TextBlock x:Name="DisplayText"
                       Text="Press a shortcut…"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="18" />
        </Border>

        <TextBlock Grid.Row="2"
                   x:Name="HintText"
                   Foreground="#FFB00000"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Clear shortcut" Width="100" Margin="0,0,8,0" Click="Clear_Click" />
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click" />
            <Button Content="Cancel" Width="80" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
